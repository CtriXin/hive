{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["orchestrator/**/*.ts", "mcp-server/**/*.ts", "bin/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
